<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="scooters-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.scooters_rent.model.Juicer</class>
        <class>com.scooters_rent.model.Juicer</class>
        <class>com.scooters_rent.model.Model</class>
        <class>com.scooters_rent.model.Zone</class>
        <class>com.scooters_rent.model.Tariff</class>
        <class>com.scooters_rent.model.User</class>
        <class>com.scooters_rent.model.Scooter</class>
        <class>com.scooters_rent.model.Route</class>
        <class>com.scooters_rent.model.Trip</class>
        <class>com.scooters_rent.model.Task</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/scootersRental_d"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="postgres"/>
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>

            <property name="hibernate.hbm2ddl.auto" value="create"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

            <!-- Отключаем показ SQL -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.highlight_sql" value="false"/>
            <property name="hibernate.use_sql_comments" value="false"/>


            <!-- Отключаем логирование через JUL -->
            <property name="hibernate.jdbc.logging_enabled" value="false"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.highlight_sql" value="true"/>
            <property name="hibernate.use_sql_comments" value="false"/>
            <property name="hibernate.jdbc.logging_enabled" value="false"/>
            <property name="hibernate.connection.autocommit" value="true"/>
        </properties>
    </persistence-unit>
</persistence>